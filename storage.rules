rules_version = '2';

// Cloud Storage security rules. Two logical buckets share the one physical
// bucket, gated by path prefix — mirroring the Firestore model in
// firestore.rules. See lib/storage.ts for the matching path builders.
service firebase.storage {
  match /b/{bucket}/o {

    // Per-user private assets: a signed-in user reads/writes only beneath their
    // own users/{uid} prefix. Uploads are capped at 500 MB.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (request.resource == null
                       || request.resource.size < 500 * 1024 * 1024);
    }

    // Shared internal library: any signed-in user can read; writes are performed
    // server-side (Admin SDK / Firebase console) and are denied from the client.
    match /internal/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Everything else is closed by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
