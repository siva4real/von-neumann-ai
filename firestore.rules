rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user workspace: a signed-in user can only read/write documents
    // beneath their own users/{uid} tree. Everything (projects, chats,
    // messages, assets, accounts, campaigns) lives under that tree.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared internal asset library: metadata for org-owned assets, readable by
    // any signed-in user. Writes are done server-side (Admin SDK / console) and
    // are denied from the client, matching the internal/ storage prefix rule.
    match /internalAssets/{assetId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
